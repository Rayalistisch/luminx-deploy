{
  "name": "luminx",
  "version": "0.2.0",
  "type": "module",
  "description": "Manage your CMS content model from a config file. Deterministic, reviewable, reversible.",
  "keywords": [
    "cms",
    "craft-cms",
    "content-model",
    "astro",
    "codegen",
    "infrastructure-as-code"
  ],
  "license": "MIT",
  "bin": {
    "luminx": "./dist/bin/luminx.js"
  },
  "files": [
    "dist/bin"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b && node build.js"
  },
  "dependencies": {
    "jsonc-parser": "3.3.1",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@luminx/adapter-craft": "workspace:*",
    "@luminx/codegen": "workspace:*",
    "@luminx/core": "workspace:*",
    "@luminx/parsers": "workspace:*",
    "@luminx/shared": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rayalistisch/luminx-deploy.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Rayalistisch/luminx-deploy#readme",
  "bugs": "https://github.com/Rayalistisch/luminx-deploy/issues"
}
