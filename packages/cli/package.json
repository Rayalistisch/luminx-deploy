{
  "name": "luminx",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "LuminX CLI \u2014 deterministic content model generation for modern CMSes.",
  "license": "MIT",
  "bin": {
    "luminx": "./dist/bin/luminx.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@luminx/adapter-craft": "workspace:*",
    "@luminx/codegen": "workspace:*",
    "@luminx/core": "workspace:*",
    "@luminx/parsers": "workspace:*",
    "@luminx/shared": "workspace:*"
  }
}
