{
  "name": "luminx/craft-luminx",
  "description": "LuminX executor for Craft CMS 5. Reads and applies a content model computed by the LuminX CLI.",
  "type": "craft-plugin",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "craftcms/cms": "^5.0"
  },
  "require-dev": {
    "pestphp/pest": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "luminx\\craft\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "luminx\\craft\\tests\\": "tests/"
    }
  },
  "extra": {
    "handle": "luminx",
    "name": "LuminX",
    "class": "luminx\\craft\\Plugin"
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": false,
      "yiisoft/yii2-composer": true,
      "pestphp/pest-plugin": true
    },
    "sort-packages": true
  },
  "scripts": {
    "test": "pest"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
